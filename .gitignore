# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environments
venv/
.venv/
env/

# PyInstaller
build/
dist/
*.spec
!hotkeys_mac.spec
!hotkeys.spec
!build_dist.py

# Private keys — NEVER commit
_bundled_keys.py

# Release / installer output
release/

# Portable dist user data (contains API keys, prompts — never commit)
dist/

# IDE
.vscode/
.idea/
*.suo
*.user

# Whisper models — too large for GitHub (downloaded by installer)
models/base/model.bin
models/small/model.bin
models/large-v3-turbo/

# Logs and runtime data — kept locally in logs/, never committed
logs/*
!logs/.gitkeep
*.log
build_log.txt
crash.txt
stderr.txt
config.json
history.json

# OS
.DS_Store
Thumbs.db

# HuggingFace download cache (kept on E:, never on C:)
.hf_cache/

# Transient YT-dlp downloads (auto-deleted after each job, never committed)
.transcripts_cache/

# Local test extractions / experiments — not part of the source tree
test-dist/
v30-test/
v30-test-zip.zip
.test_dest/
.test_*/

# Debug screenshots from manual UI testing
.tr_after*.png
.tt_*.png
.wheel_test.png

# Transient debug scripts and test harnesses
.human_test_plan.md
.regression_sweep.py
test_ipc_harness.py
test_diarize_integration.py
dist_audit.py

# Auto-generated test artifacts
test_output_*.gif
test_output_*.png

# Working-notes files superseded by DIST_BUILD_LEARNINGS.md
DIST_FIXES.md
FIXES.md
to\ do\ list.pdf

# Build artifact (auto-regenerated by hotkeys.spec from brand_icon.py)
build_icon.ico

# Heavy bundled assets — not committed to the repo. Each is fetched or built
# separately by the build pipeline so the repo stays small:
#   audio_editor_assets/tenacity/  — Tenacity portable build (~200 MB)
#   whiteboard_assets/dist/        — Excalidraw offline bundle (~22 MB)
#   assets/diarization/            — pyannote pretrained model (~33 MB)
# If you need to develop locally, download / build these into the listed
# paths; the build_dist.py spec expects them at those locations.
audio_editor_assets/
whiteboard_assets/dist/
whiteboard_assets/node_modules/
assets/diarization/
models/large-v3/

# Demo / docs generation tooling (heavy media + transient outputs)
demo/
